# Liquidity Forecaster — environment template
#
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env
#
# `.env` is git-ignored and MUST NEVER be committed. Do not paste secrets into
# chat, tickets, or commit messages. See docs/06-security.md and docs/SECRETS.md.
# Placeholder values below are NOT real credentials.

# ─── Folio API (read-only banking access) ────────────────────────────────────
# Create / rotate keys at https://app.folio.no/til/api-tilgang
FOLIO_API_KEY=replace-me
FOLIO_API_BASE_URL=https://api.folio.no/v2
# Optional: which Operational account to forecast (only if you run more than one).
FOLIO_OPERATIONAL_ACCOUNT=

# ─── Slack alerting (channel: #finance) ──────────────────────────────────────
# Provide ONE of the following. Incoming webhook is simplest.
SLACK_WEBHOOK_URL=
# or, if using a bot token instead of a webhook:
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#finance

# ─── Email fallback (used only when Slack delivery fails) ─────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=kai@chenmedia.no

# ─── Phase 2 (all optional) ──────────────────────────────────────────────────
# Recurring run-rate baseline from balance history (on by default). Set to off
# to project from scheduled items only.
FORECAST_BASELINE=on
# Path to a JSON list of expected client inflows not yet in Folio.
# See expected_inflows.example.json for the format.
EXPECTED_INFLOWS_FILE=
# Currency→NOK conversion rates for foreign payments (JSON). Without a rate, a
# foreign payment is counted at face value and flagged FX-variable.
FX_RATES={"EUR":"11.50","USD":"10.80"}

# ─── Web dashboard (Vercel) ──────────────────────────────────────────────────
# Shared secret gating /api/forecast. Required to serve the dashboard (fails closed).
DASHBOARD_TOKEN=
# On Vercel the filesystem is read-only except /tmp:
# FORECAST_DB_PATH=/tmp/forecaster.db
