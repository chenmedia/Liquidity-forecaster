# Liquidity Forecaster — environment template
#
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env
#
# `.env` is git-ignored and MUST NEVER be committed. Do not paste secrets into
# chat, tickets, or commit messages. See docs/06-security.md and docs/SECRETS.md.
# Placeholder values below are NOT real credentials.

# ─── Folio API (read-only banking access) ────────────────────────────────────
# Create / rotate keys at https://app.folio.no/til/api-tilgang
FOLIO_API_KEY=replace-me
FOLIO_API_BASE_URL=https://api.folio.no/v2
# Optional: which Operational account to forecast (only if you run more than one).
FOLIO_OPERATIONAL_ACCOUNT=

# ─── Slack alerting (channel: #finance) ──────────────────────────────────────
# Provide ONE of the following. Incoming webhook is simplest.
SLACK_WEBHOOK_URL=
# or, if using a bot token instead of a webhook:
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#finance

# ─── Email fallback (used only when Slack delivery fails) ─────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=kai@chenmedia.no
